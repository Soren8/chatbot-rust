# Secrets only — non-secret configuration belongs in .config.yml
SECRET_KEY=your-secret-key-here
OPENAI_API_KEY=your-openai-key
OPENROUTER_API_KEY=your-openrouter-key
XAI_API_KEY=your-xai-key
BRAVE_API_KEY=your-brave-api-key  # Required for web search on non-XAI providers; get a free key at brave.com/search/api
