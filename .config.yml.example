# User-defined variables — referenced as ${VAR_NAME} anywhere below.
# Environment variables (from .env) take precedence over these.
vars:
  LOCAL_HOST: host.docker.internal
  LOCAL_PORT: 11434

# TTS / Voice configuration
tts_provider: "kokoro"  # Options: kokoro, qwen, fish
tts_voice: "bf_emma"   # Voice for Kokoro. Other options: af_heart, af_bella, am_adam, bm_george
# tts_voice: "Ryan"     # Voice preset for Qwen3-TTS (qwen provider)
stt_enabled: true

# Voice service connection (the vertically integrated chatbot-cuda container)
voice_service_host: localhost
voice_service_port: 5100
# GPU device index (as shown by nvidia-smi) for the voice service.
# Set to 0 for the first GPU, 1 for the second, etc.
voice_gpu_device: 0

default_llm: "Local LLM (Free Tier)"
default_system_prompt: "You are a helpful AI assistant. Provide clear and concise answers to user queries."
session_timeout: 3600
csrf: off # Set to 'off' only for development (localhost over HTTP); this also disables the 'Secure' flag on session cookies.
save_thoughts: true
send_thoughts: false

llms:
  - provider_name: "Local LLM (Free Tier)"
    type: "openai"
    base_url: "http://${LOCAL_HOST}:${LOCAL_PORT}/v1"
    model_name: "dolphin3.1-8b"
    context_size: 8192
    tier: "free"
    search: true  # Enables Brave Search (requires BRAVE_API_KEY)

  - provider_name: "GPT-4 (Premium)"
    type: "openai"
    api_key: "${OPENAI_API_KEY}"
    model_name: "gpt-4-turbo"
    tier: "premium"
    search: true  # Enables Brave Search (requires BRAVE_API_KEY)

  - provider_name: "Grok (XAI)"
    type: "xai"
    api_key: "${XAI_API_KEY}"
    model_name: "grok-3-mini"
    tier: "premium"
    search: true
    # xai_search: true   # Default: use XAI's web search tool (no BRAVE_API_KEY needed)
    # xai_search: false  # Use Brave Search instead (requires BRAVE_API_KEY)
