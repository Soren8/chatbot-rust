[
  {
    "_comment": "Bind-mount stubs OVER host paths so agents never see live secrets. Add one entry per repo.",
    "source": "${localWorkspaceFolder}/.devcontainer/stubs/.env",
    "target": "/workspace/.env",
    "type": "bind",
    "readonly": true
  },
  {
    "source": "${localWorkspaceFolder}/.config.yml.example",
    "target": "/workspace/.config.yml",
    "type": "bind",
    "readonly": true
  },
  {
    "source": "${localWorkspaceFolder}/.devcontainer/stubs/data",
    "target": "/workspace/data",
    "type": "bind",
    "readonly": true
  }
]